<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Seven Stump Flower Farm | Coventry, Rhode Island</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --maroon:#6b1a28;
  --maroon-deep:#4a0e1a;
  --maroon-mid:#8b2535;
  --maroon-light:#b85a6a;
  --maroon-pale:#e8c4cb;
  --maroon-blush:#f4e0e3;
  --cream:#f8f2eb;
  --cream-warm:#efe6d8;
  --warm-white:#faf7f3;
  --text-dark:#1e1215;
  --text-mid:#4a2830;
  --gold:#c4943a;
  --gold-light:#d9ae68;
  --sw:230px;
}
html{scroll-behavior:smooth}
body{font-family:'Jost',sans-serif;background:var(--warm-white);color:var(--text-dark);overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:.25}

/* ── SIDEBAR ── */
#sidebar{position:fixed;top:0;left:0;width:var(–sw);height:100vh;background:var(–maroon-deep);z-index:200;display:flex;flex-direction:column;padding:2rem 0;border-right:1px solid rgba(184,90,106,.15);transition:transform .4s cubic-bezier(.4,0,.2,1)}
#sidebar.collapsed{transform:translateX(calc(-1 * var(–sw)))}
.sb-logo{padding:0 1.5rem 1.8rem;border-bottom:1px solid rgba(184,90,106,.15);display:flex;flex-direction:column;align-items:center;gap:.6rem}
/* Sidebar uses the maroon flower oval mark */
.sb-logo img{width:80px;height:auto}
.sb-logo-sub{font-size:.53rem;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(–maroon-pale);text-align:center}
.sb-nav{flex:1;padding:1rem 0;overflow-y:auto}
.sb-sec-lbl{font-size:.5rem;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:rgba(232,196,203,.28);padding:.9rem 1.8rem .4rem}
.sb-link{display:flex;align-items:center;gap:.7rem;padding:.58rem 1.8rem;text-decoration:none;font-size:.77rem;font-weight:400;color:var(–maroon-pale);letter-spacing:.03em;transition:color .2s,background .2s,padding-left .2s;position:relative}
.sb-link::before{content:’’;position:absolute;left:0;top:20%;height:60%;width:2px;background:var(–gold);transform:scaleY(0);transition:transform .2s}
.sb-link:hover,.sb-link.active{color:var(–cream);background:rgba(255,255,255,.05);padding-left:2.2rem}
.sb-link:hover::before,.sb-link.active::before{transform:scaleY(1)}
.sb-link svg{width:13px;height:13px;flex-shrink:0;opacity:.5;transition:opacity .2s}
.sb-link:hover svg,.sb-link.active svg{opacity:1}
.sb-foot{padding:1.5rem 1.8rem;border-top:1px solid rgba(184,90,106,.15)}
.sb-social{font-family:‘Cormorant Garamond’,serif;font-size:.8rem;font-style:italic;color:var(–maroon-light);text-decoration:none;transition:color .2s}
.sb-social:hover{color:var(–gold-light)}

#sb-toggle{position:fixed;top:1.3rem;left:1.3rem;z-index:300;width:40px;height:40px;background:var(–maroon-deep);border:1px solid rgba(184,90,106,.25);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;transition:left .4s cubic-bezier(.4,0,.2,1)}
#sb-toggle.open{left:calc(var(–sw) + 1rem)}
#sb-toggle span{display:block;width:18px;height:1.5px;background:var(–maroon-pale);transition:transform .3s,opacity .3s,width .3s}
#sb-toggle.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
#sb-toggle.open span:nth-child(2){opacity:0;width:0}
#sb-toggle.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}

#mc{margin-left:var(–sw);transition:margin-left .4s cubic-bezier(.4,0,.2,1)}
#mc.fw{margin-left:0}
#top-nav{position:fixed;top:0;left:var(–sw);right:0;z-index:100;padding:.9rem 2.5rem;display:flex;justify-content:flex-end;transition:left .4s cubic-bezier(.4,0,.2,1),background .3s}
#top-nav.scrolled{background:rgba(74,14,26,.94);backdrop-filter:blur(12px)}
#top-nav.fw{left:0}
.nav-cta{font-size:.65rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(–cream);background:var(–maroon);padding:.52rem 1.5rem;text-decoration:none;transition:background .2s;border:1px solid rgba(184,90,106,.4)}
.nav-cta:hover{background:var(–maroon-mid)}

/* ── SHARED ── */
section{position:relative}
.inner{max-width:1100px;margin:0 auto;padding:0 3rem}
.sec-lbl{font-size:.6rem;font-weight:700;letter-spacing:.35em;text-transform:uppercase;color:var(–maroon-light);margin-bottom:.75rem}
.sec-title{font-family:‘Cormorant Garamond’,serif;font-size:clamp(1.9rem,3.2vw,3rem);font-weight:400;line-height:1.1;color:var(–text-dark)}
.sec-title em{font-style:italic;color:var(–maroon-mid)}
.btn-p{display:inline-block;padding:.82rem 2.2rem;background:var(–maroon);color:var(–cream);font-size:.67rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;transition:background .2s,transform .2s;border:none;cursor:pointer;font-family:‘Jost’,sans-serif}
.btn-p:hover{background:var(–maroon-mid);transform:translateY(-2px)}
.btn-o{display:inline-block;padding:.82rem 2.2rem;border:1px solid var(–maroon-light);color:var(–maroon);font-size:.67rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;transition:border-color .2s,color .2s,transform .2s}
.btn-o:hover{border-color:var(–maroon-mid);color:var(–maroon-mid);transform:translateY(-2px)}

/* ── HERO ── */
#hero{min-height:100vh;background:var(–maroon-deep);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
.hero-mosaic{position:absolute;inset:0;display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(2,1fr)}
.hero-tile{background-size:cover;background-position:center;background-color:#3a0d16}
.hero-tile.loaded{filter:saturate(.65) brightness(.35)}
.hero-tile:not(.loaded){opacity:.1}
.hero-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(74,14,26,.42) 0%,rgba(74,14,26,.9) 100%)}
.hero-content{position:relative;z-index:2;text-align:center;padding:8rem 2rem 6rem;max-width:820px;display:flex;flex-direction:column;align-items:center}
/* Hero uses the stump oval logo */
.hero-logo{width:190px;height:auto;margin-bottom:1.8rem;opacity:0;animation:fadeUp 1s ease .1s forwards;
filter:drop-shadow(0 2px 12px rgba(74,14,26,.4))}
.hero-eyebrow{font-size:.63rem;font-weight:600;letter-spacing:.35em;text-transform:uppercase;color:var(–gold);margin-bottom:1.2rem;opacity:0;animation:fadeUp .9s ease .4s forwards}
.hero-title{font-family:‘Cormorant Garamond’,serif;font-size:clamp(2.8rem,7vw,6.5rem);font-weight:300;line-height:.95;color:var(–cream);margin-bottom:.2em;opacity:0;animation:fadeUp 1s ease .6s forwards}
.hero-title em{font-style:italic;color:var(–maroon-pale)}
.hero-div{width:50px;height:1px;background:var(–gold);margin:1.4rem auto;opacity:0;animation:fadeUp .8s ease .85s forwards}
.hero-tag{font-family:‘Cormorant Garamond’,serif;font-size:clamp(.9rem,1.8vw,1.2rem);font-weight:300;font-style:italic;color:var(–maroon-pale);line-height:1.6;max-width:440px;margin:0 auto 2.4rem;opacity:0;animation:fadeUp .8s ease 1s forwards}
.hero-ctas{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;opacity:0;animation:fadeUp .8s ease 1.15s forwards}
.hero-scroll{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;opacity:0;animation:fadeIn 1s ease 1.6s forwards}
.hero-scroll span{font-size:.55rem;letter-spacing:.3em;text-transform:uppercase;color:var(–maroon-light)}
.scroll-line{width:1px;height:34px;background:linear-gradient(to bottom,var(–maroon-light),transparent);animation:scrollPulse 2.2s ease infinite}

/* ── ABOUT ── */
#about{background:var(–cream);padding:7rem 0}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.about-img-ph{width:100%;aspect-ratio:4/5;object-fit:cover;display:block;background:var(–maroon-blush);min-height:200px}
.about-quote{background:var(–maroon);color:var(–cream);padding:1.5rem 2rem 1.5rem 2.6rem;font-family:‘Cormorant Garamond’,serif;font-size:1rem;font-style:italic;font-weight:300;line-height:1.5;position:relative;margin-top:.5rem}
.about-quote::before{content:’”’;font-size:3.5rem;line-height:0;position:absolute;top:1.4rem;left:1.1rem;color:var(–gold);opacity:.35}
.about-text .sec-title{margin-bottom:1.4rem}
.about-body{font-size:.93rem;font-weight:300;line-height:1.9;color:var(–text-mid);margin-bottom:1.1rem}
.about-stats{display:flex;gap:2.5rem;margin-top:2.5rem;padding-top:1.8rem;border-top:1px solid var(–maroon-blush)}
.stat-n{font-family:‘Cormorant Garamond’,serif;font-size:2.5rem;font-weight:300;color:var(–maroon);line-height:1}
.stat-l{font-size:.6rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(–maroon-light);margin-top:.25rem}

/* ── PHOTO STRIP ── */
.photo-strip{height:460px;position:relative;overflow:hidden;background:var(–maroon-deep)}
.ps-bg{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity .8s ease}
.ps-bg.loaded{opacity:1}
.ps-ov{position:absolute;inset:0;background:linear-gradient(to right,rgba(74,14,26,.82) 0%,rgba(74,14,26,.45) 50%,rgba(74,14,26,.82) 100%)}
.ps-text{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:2rem}
.ps-text blockquote{font-family:‘Cormorant Garamond’,serif;font-size:clamp(1.3rem,3vw,2.1rem);font-weight:300;font-style:italic;color:var(–cream);max-width:680px;line-height:1.5;margin-bottom:1rem}
.ps-text cite{font-size:.6rem;font-weight:600;letter-spacing:.25em;text-transform:uppercase;color:var(–gold)}

/* ── WIDE LOGO BANNER ── */
#logo-banner{background:var(–cream-warm);padding:4rem 0;overflow:hidden;border-top:1px solid var(–maroon-blush);border-bottom:1px solid var(–maroon-blush)}
.logo-banner-inner{display:flex;flex-direction:column;align-items:center;gap:1.2rem}
/* Wide text logo — large, centered, natural colors */
.logo-banner-wide{max-width:600px;width:85%;height:auto;opacity:.9}
.logo-banner-sub{font-size:.62rem;font-weight:600;letter-spacing:.3em;text-transform:uppercase;color:var(–maroon-light)}

/* ── GALLERY ── */
#gallery{background:var(–warm-white);padding:7rem 0}
.gallery-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2.8rem;flex-wrap:wrap;gap:1.5rem}
.gallery-tabs{display:flex;gap:.4rem;flex-wrap:wrap}
.gtab{font-size:.6rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;padding:.38rem .9rem;border:1px solid var(–maroon-blush);color:var(–maroon-light);background:transparent;cursor:pointer;transition:background .2s,color .2s,border-color .2s}
.gtab.active,.gtab:hover{background:var(–maroon);color:var(–cream);border-color:var(–maroon)}
.gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:215px;gap:7px}
.gcell{position:relative;overflow:hidden;cursor:pointer;background:var(–maroon-blush)}
.gcell.tall{grid-row:span 2}.gcell.wide{grid-column:span 2}
.gcell img{width:100%;height:100%;object-fit:cover;display:block;opacity:0;transition:opacity .5s,transform .6s}
.gcell img.loaded{opacity:1}
.gcell:hover img{transform:scale(1.06)}
.gcell-ph{position:absolute;inset:0;display:flex;align-items:flex-end;padding:.8rem}
.gcell-ph-tag{font-size:.54rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:rgba(255,255,255,.7);background:rgba(74,14,26,.4);padding:.2rem .48rem}
.gcell-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(74,14,26,.78) 0%,transparent 55%);opacity:0;transition:opacity .4s;display:flex;align-items:flex-end;padding:1rem}
.gcell:hover .gcell-ov{opacity:1}
.gcell-cap{font-family:‘Cormorant Garamond’,serif;font-size:.88rem;font-style:italic;font-weight:300;color:var(–cream)}
.gph-b1{background:linear-gradient(145deg,#c8a090,#a87060)}.gph-b2{background:linear-gradient(145deg,#d9b8a8,#c0958a)}
.gph-b3{background:linear-gradient(145deg,#b88070,#d4aa9a)}.gph-b4{background:linear-gradient(145deg,#a06050,#e2cabb)}
.gph-f1{background:linear-gradient(145deg,#8b2535,#6b1a28)}.gph-f2{background:linear-gradient(145deg,#6b1a28,#4a0e1a)}
.gph-f3{background:linear-gradient(145deg,#e8c4cb,#d4a0aa)}.gph-a1{background:linear-gradient(145deg,#c4943a,#a07030)}
.gph-a2{background:linear-gradient(145deg,#806030,#a08040)}.gph-e1{background:linear-gradient(145deg,#4a0e1a,#6b1a28)}
.gph-e2{background:linear-gradient(145deg,#3a0d16,#4a0e1a)}.gph-mk{background:linear-gradient(145deg,#6b1a28,#8b2535)}
.gallery-cta{text-align:center;margin-top:2rem}
.gallery-cta a{font-size:.63rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(–maroon);text-decoration:none;border-bottom:1px solid var(–maroon-blush);padding-bottom:.15rem;transition:color .2s,border-color .2s}
.gallery-cta a:hover{color:var(–gold);border-color:var(–gold)}

/* ── VARIETIES ── */
#varieties{background:var(–maroon-deep);padding:7rem 0}
#varieties .sec-lbl{color:var(–gold)}
#varieties .sec-title{color:var(–cream);margin-bottom:.7rem}
.var-intro{font-family:‘Cormorant Garamond’,serif;font-size:1.05rem;font-style:italic;font-weight:300;color:var(–maroon-pale);line-height:1.7;max-width:480px;margin-bottom:3rem}
.var-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.vcard{background:var(–maroon);padding:2rem 1.8rem;position:relative;overflow:hidden;transition:background .3s}
.vcard::before{content:’’;position:absolute;top:0;left:0;width:3px;height:0;background:var(–gold);transition:height .3s}
.vcard:hover{background:var(–maroon-mid)}.vcard:hover::before{height:100%}
.vname{font-family:‘Cormorant Garamond’,serif;font-size:1.35rem;font-weight:400;color:var(–cream);margin-bottom:.3rem}
.vcult{font-size:.74rem;font-weight:300;color:var(–maroon-pale);line-height:1.7;font-style:italic}
.vsea{display:inline-block;margin-top:.75rem;font-size:.55rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(–gold);border:1px solid rgba(196,148,58,.35);padding:.17rem .52rem}

/* ── CSA ── */
#csa{padding:7rem 0;position:relative;overflow:hidden}
.csa-bg{position:absolute;inset:0;background-color:var(–warm-white);background-size:cover;background-position:center}
.csa-bg::after{content:’’;position:absolute;inset:0;background:rgba(250,247,243,.93)}
.csa-inner{position:relative;z-index:2;padding:7rem 0}
.csa-layout{display:grid;grid-template-columns:1fr 1.1fr;gap:5rem;align-items:start}
.csa-text .sec-title{margin-bottom:1.4rem}
.csa-body{font-size:.91rem;font-weight:300;line-height:1.9;color:var(–text-mid);margin-bottom:1.1rem}
.csa-tiers{display:flex;flex-direction:column;gap:1.1rem}
.ctier{border:1px solid var(–maroon-blush);padding:1.7rem 1.9rem;position:relative;background:rgba(255,255,255,.9);transition:border-color .2s,box-shadow .2s}
.ctier:hover{border-color:var(–maroon-light);box-shadow:0 8px 28px rgba(107,26,40,.08)}
.ctier.feat{border-color:var(–maroon);background:linear-gradient(135deg,rgba(107,26,40,.05),rgba(255,255,255,.95) 60%)}
.cbadge{position:absolute;top:-.68rem;left:1.5rem;background:var(–maroon);color:var(–cream);font-size:.53rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;padding:.15rem .65rem}
.ctier-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:.55rem}
.ctname{font-family:‘Cormorant Garamond’,serif;font-size:1.3rem;font-weight:500;color:var(–text-dark)}
.ctprice{font-family:‘Cormorant Garamond’,serif;font-size:1.15rem;font-weight:400;color:var(–maroon)}
.ctprice span{font-family:‘Jost’,sans-serif;font-size:.65rem;color:var(–maroon-light)}
.ctdesc{font-size:.8rem;font-weight:300;color:var(–text-mid);line-height:1.75}
.csa-note{margin-top:1.4rem;font-size:.76rem;font-weight:300;color:var(–maroon-light);font-style:italic}

/* ── EVENTS ── */
#events{background:var(–cream-warm);padding:7rem 0}
.ev-head{margin-bottom:3rem}
.ev-head .sec-title{margin-bottom:.7rem}
.ev-sub{font-size:.91rem;font-weight:300;color:var(–text-mid);line-height:1.8;max-width:500px}
.ev-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem}
.ephoto{aspect-ratio:3/4;position:relative;overflow:hidden;background:var(–maroon-blush);background-size:cover;background-position:center}
.ephoto img{width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;opacity:0;transition:opacity .6s}
.ephoto img.loaded{opacity:1}
.ephoto-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(74,14,26,.88) 0%,transparent 55%);display:flex;align-items:flex-end;padding:1.4rem}
.ename{font-family:‘Cormorant Garamond’,serif;font-size:1.2rem;font-weight:400;color:var(–cream);margin-bottom:.2rem}
.edate{font-size:.61rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(–gold)}
.ev-cta{text-align:center;margin-top:2.8rem}

/* ── MARKETS ── */
#markets{position:relative;overflow:hidden;padding:7rem 0}
.markets-bg{position:absolute;inset:0;background-color:var(–maroon-deep);background-size:cover;background-position:center}
.markets-bg::after{content:’’;position:absolute;inset:0;background:rgba(74,14,26,.88)}
.markets-inner{position:relative;z-index:2}
#markets .sec-lbl{color:var(–gold)}
#markets .sec-title{color:var(–cream);margin-bottom:3.2rem}
.mkt-grid{display:grid;grid-template-columns:2fr 1fr;gap:2.5rem;align-items:start}
.mkt-card{background:rgba(255,255,255,.06);border:1px solid rgba(232,196,203,.2);padding:2.6rem;position:relative}
.mkt-card::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(–gold),transparent)}
.mkt-name{font-family:‘Cormorant Garamond’,serif;font-size:1.75rem;font-weight:400;color:var(–cream);margin-bottom:.35rem}
.mkt-loc{font-size:.68rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(–maroon-pale);margin-bottom:1.8rem}
.mkt-row{display:flex;align-items:flex-start;gap:.85rem;margin-bottom:.85rem}
.mkt-icon{width:26px;height:26px;background:rgba(196,148,58,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.05rem}
.mkt-icon svg{width:13px;height:13px}
.mkt-txt{font-size:.82rem;font-weight:300;color:var(–maroon-pale);line-height:1.5}
.mkt-txt strong{font-weight:500;color:var(–cream)}
.mkt-tag{display:inline-block;margin-top:1.3rem;background:rgba(196,148,58,.12);border:1px solid rgba(196,148,58,.38);color:var(–gold-light);font-size:.59rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;padding:.24rem .68rem}
.mkt-side{display:flex;flex-direction:column;gap:1.1rem}
.mkt-info{background:rgba(255,255,255,.05);border:1px solid rgba(232,196,203,.15);padding:1.7rem}
.mkt-info-lbl{font-size:.55rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(–gold);margin-bottom:.65rem}
.mkt-info-txt{font-family:‘Cormorant Garamond’,serif;font-size:.93rem;font-weight:300;color:var(–maroon-pale);line-height:1.7}

/* ── WORKSHOPS ── */
#workshops{padding:7rem 0;position:relative;overflow:hidden}
.ws-bg{position:absolute;inset:0;background-color:var(–cream);background-size:cover;background-position:center}
.ws-bg::after{content:’’;position:absolute;inset:0;background:rgba(248,242,235,.92)}
.ws-inner{position:relative;z-index:2}
.ws-head{max-width:540px;margin-bottom:3.2rem}
.ws-head .sec-title{margin-bottom:.9rem}
.ws-sub{font-size:.91rem;font-weight:300;color:var(–text-mid);line-height:1.8}
.ws-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem}
.wcard{background:rgba(250,247,243,.95);padding:2.1rem 1.7rem;border-bottom:3px solid transparent;transition:border-color .3s,transform .3s,box-shadow .3s}
.wcard:hover{border-color:var(–maroon-light);transform:translateY(-4px);box-shadow:0 14px 36px rgba(107,26,40,.1)}
.wnum{font-family:‘Cormorant Garamond’,serif;font-size:2.4rem;font-weight:300;color:var(–maroon-blush);line-height:1;margin-bottom:.75rem}
.wtitle{font-family:‘Cormorant Garamond’,serif;font-size:1.25rem;font-weight:500;color:var(–text-dark);margin-bottom:.55rem}
.wdesc{font-size:.8rem;font-weight:300;color:var(–text-mid);line-height:1.75}
.wstatus{display:inline-block;margin-top:1.1rem;font-size:.58rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(–maroon-light)}

/* ── CONTACT ── */
#contact{background:var(–maroon);padding:7rem 0}
.con-layout{display:grid;grid-template-columns:1fr 1.3fr;gap:5rem;align-items:start}
#contact .sec-lbl{color:var(–gold)}
#contact .sec-title{color:var(–cream);margin-bottom:1.1rem}
.con-body{font-size:.88rem;font-weight:300;color:var(–maroon-pale);line-height:1.85;margin-bottom:1.8rem}
.con-details{display:flex;flex-direction:column;gap:.85rem}
.con-row{display:flex;align-items:flex-start;gap:.75rem}
.con-row svg{width:14px;height:14px;color:var(–gold);flex-shrink:0;margin-top:.15rem}
.con-info{font-size:.8rem;font-weight:300;color:var(–maroon-pale);line-height:1.6}
.con-info strong{display:block;font-weight:500;color:var(–cream)}
.con-social{margin-top:2.2rem;display:flex;align-items:center;gap:.8rem}
.soc-lbl{font-size:.57rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(–maroon-light)}
.soc-link{font-family:‘Cormorant Garamond’,serif;font-size:.95rem;font-style:italic;color:var(–maroon-pale);text-decoration:none;transition:color .2s}
.soc-link:hover{color:var(–gold-light)}
.con-form{display:flex;flex-direction:column;gap:.95rem}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:.95rem}
.fg{display:flex;flex-direction:column;gap:.38rem}
.fg label{font-size:.57rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(–maroon-pale)}
.fg input,.fg select,.fg textarea{background:rgba(255,255,255,.08);border:1px solid rgba(232,196,203,.25);color:var(–cream);font-family:‘Jost’,sans-serif;font-size:.86rem;font-weight:300;padding:.82rem 1rem;outline:none;transition:border-color .2s;width:100%}
.fg input::placeholder,.fg textarea::placeholder{color:rgba(232,196,203,.4)}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(–maroon-pale)}
.fg select option{background:var(–maroon)}
.fg textarea{resize:vertical;min-height:105px}
.fsub{padding:.92rem 2.4rem;background:var(–gold);color:var(–maroon-deep);font-family:‘Jost’,sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;border:none;cursor:pointer;transition:background .2s;align-self:flex-start}
.fsub:hover{background:var(–gold-light)}

/* ── FOOTER ── */
footer{background:var(–maroon-deep);padding:2.4rem 3rem;display:flex;align-items:center;justify-content:space-between;border-top:1px solid rgba(184,90,106,.15)}
.ft-logo{height:48px;width:auto}
.ft-copy{font-size:.62rem;font-weight:300;color:var(–maroon-light)}
.ft-links{display:flex;gap:2rem;list-style:none}
.ft-links a{font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(–maroon-light);text-decoration:none;transition:color .2s}
.ft-links a:hover{color:var(–gold-light)}

/* ── LIGHTBOX ── */
#lightbox{display:none;position:fixed;inset:0;z-index:500;background:rgba(74,14,26,.97);align-items:center;justify-content:center}
#lightbox.open{display:flex}
.lb-inner{position:relative;max-width:88vw;max-height:88vh}
#lb-img{max-width:100%;max-height:88vh;object-fit:contain;display:block}
.lb-close{position:absolute;top:-2.4rem;right:0;background:none;border:none;color:var(–cream);font-size:1.5rem;cursor:pointer;opacity:.7;transition:opacity .2s}
.lb-close:hover{opacity:1}
.lb-cap{position:absolute;bottom:-2.3rem;left:0;font-family:‘Cormorant Garamond’,serif;font-size:.93rem;font-style:italic;color:var(–maroon-pale)}
.lb-nav{position:absolute;top:50%;transform:translateY(-50%);display:flex;justify-content:space-between;width:calc(100% + 6rem);left:-3rem;pointer-events:none}
.lb-arrow{background:none;border:none;color:rgba(255,255,255,.55);font-size:2rem;cursor:pointer;padding:.5rem;transition:color .2s;pointer-events:all}
.lb-arrow:hover{color:var(–gold)}

#status-panel{position:fixed;bottom:1rem;right:1rem;z-index:9000;max-width:380px;background:#1e0810;border:1px solid var(–gold);font-family:monospace;font-size:.73rem;color:var(–maroon-pale);padding:.8rem 1rem;line-height:1.6;display:none;max-height:240px;overflow-y:auto;border-radius:2px}

@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scrollPulse{0%,100%{opacity:.35}50%{opacity:1}}
.reveal{opacity:0;transform:translateY(26px);transition:opacity .75s ease,transform .75s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.rd1{transition-delay:.1s}.rd2{transition-delay:.2s}.rd3{transition-delay:.3s}.rd4{transition-delay:.4s}.rd5{transition-delay:.5s}.rd6{transition-delay:.6s}

@media(max-width:1024px){:root{–sw:200px}.inner{padding:0 2rem}}
@media(max-width:768px){
#sidebar{transform:translateX(calc(-1 * var(–sw)))}#sidebar.mob-open{transform:translateX(0)}
#sb-toggle{left:1rem}#sb-toggle.open{left:calc(var(–sw) + .5rem)}
#mc{margin-left:0!important}#top-nav{left:0!important}
.inner{padding:0 1.4rem}
.about-grid,.csa-layout,.mkt-grid,.con-layout{grid-template-columns:1fr;gap:2.5rem}
.var-grid,.ws-grid,.ev-grid{grid-template-columns:1fr 1fr}
.gallery-grid{grid-template-columns:repeat(2,1fr)}.gcell.wide{grid-column:span 1}
footer{flex-direction:column;gap:1.2rem;text-align:center}.ft-links{justify-content:center}
.about-stats{flex-wrap:wrap;gap:1.8rem}.frow{grid-template-columns:1fr}
.photo-strip{height:300px}.lb-nav{width:calc(100% + 3rem);left:-1.5rem}
.logo-banner-wide{max-width:90%}
}
@media(max-width:480px){
.var-grid,.ws-grid,.ev-grid{grid-template-columns:1fr}
.gallery-grid{grid-template-columns:1fr}.gcell.tall{grid-row:span 1}
}
</style>

